{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role and billing rate",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "member"] },
        "hourly_rate": { "type": "number" },
        "is_active": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role"]
    },
    "Client": {
      "title": "Client",
      "description": "Business client",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "billing_currency": { "type": "string" },
        "default_hourly_rate": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "archived"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "Project": {
      "title": "Project",
      "description": "Client project",
      "type": "object",
      "properties": {
        "client_id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["hourly", "fixed", "retainer"] },
        "status": { "type": "string", "enum": ["active", "on_hold", "completed"] },
        "estimated_hours": { "type": "number" },
        "logged_hours": { "type": "number" },
        "budget_amount": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["client_id", "name", "type", "status"]
    },
    "Task": {
      "title": "Task",
      "description": "Project task",
      "type": "object",
      "properties": {
        "project_id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "is_billable": { "type": "boolean" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "completed"] },
        "assigned_to": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" }
      },
      "required": ["project_id", "title", "is_billable", "status"]
    },
    "TimeLog": {
      "title": "TimeLog",
      "description": "Logged work hours",
      "type": "object",
      "properties": {
        "task_id": { "type": "string" },
        "project_id": { "type": "string" },
        "client_id": { "type": "string" },
        "user_id": { "type": "string" },
        "logged_hours": { "type": "number" },
        "is_billable": { "type": "boolean" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "is_invoiced": { "type": "boolean" },
        "invoice_id": { "type": "string" }
      },
      "required": ["task_id", "project_id", "client_id", "user_id", "logged_hours", "date"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Client invoice",
      "type": "object",
      "properties": {
        "client_id": { "type": "string" },
        "invoice_number": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "sent", "paid", "overdue"] },
        "issued_date": { "type": "string", "format": "date" },
        "due_date": { "type": "string", "format": "date" },
        "subtotal": { "type": "number" },
        "tax_amount": { "type": "number" },
        "total": { "type": "number" },
        "amount_paid": { "type": "number" },
        "notes": { "type": "string" },
        "created_by": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["client_id", "invoice_number", "status", "total"]
    },
    "InvoiceLineItem": {
      "title": "InvoiceLineItem",
      "description": "Line item on an invoice",
      "type": "object",
      "properties": {
        "invoice_id": { "type": "string" },
        "description": { "type": "string" },
        "quantity": { "type": "number" },
        "unit_rate": { "type": "number" },
        "subtotal": { "type": "number" },
        "source_type": { "type": "string", "enum": ["time_log", "task", "manual"] },
        "source_id": { "type": "string" }
      },
      "required": ["invoice_id", "description", "quantity", "unit_rate", "subtotal"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Payment received for an invoice",
      "type": "object",
      "properties": {
        "invoice_id": { "type": "string" },
        "amount": { "type": "number" },
        "payment_date": { "type": "string", "format": "date" },
        "payment_method": { "type": "string" },
        "reference_number": { "type": "string" },
        "notes": { "type": "string" },
        "recorded_by": { "type": "string" }
      },
      "required": ["invoice_id", "amount", "payment_date"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/clients/{clientId}": { "schema": "Client", "description": "Clients" },
    "/projects/{projectId}": { "schema": "Project", "description": "Projects" },
    "/tasks/{taskId}": { "schema": "Task", "description": "Tasks" },
    "/timeLogs/{logId}": { "schema": "TimeLog", "description": "Time logs" },
    "/invoices/{invoiceId}": { "schema": "Invoice", "description": "Invoices" },
    "/invoiceLineItems/{itemId}": { "schema": "InvoiceLineItem", "description": "Invoice line items" },
    "/payments/{paymentId}": { "schema": "Payment", "description": "Payments" }
  }
}
